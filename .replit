modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.development]
# ADMIN_PASSWORD must be set via Replit Secrets — do not hardcode here

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5174
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 3000

[[ports]]
localPort = 8081
externalPort = 3001

[[ports]]
localPort = 24964
externalPort = 3002
