modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/store"

[[artifacts]]
id = "artifacts/farmops-landing"

[deployment]
run = ["node", "artifacts/api-server/dist/index.mjs"]
build = ["pnpm", "run", "build"]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.development]

[userenv.shared]
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_SECURE = "false"
# ADMIN_PASSWORD must be set via Replit Secrets — do not hardcode here

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80
